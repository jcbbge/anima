{
  "imports": {
    "surrealdb": "npm:surrealdb@2.0.0-beta.2"
  },
  "tasks": {
    "mcp": "deno run --allow-net --allow-env --allow-read mcp-server/index.ts",
    "cli": "deno run --allow-net --allow-env --allow-read cli/anima.ts",
    "worker": "deno run --allow-net --allow-env --allow-read synthesis-worker/index.ts",
    "worker:once": "deno run --allow-net --allow-env --allow-read synthesis-worker/index.ts --once",
    "worker:dry-run": "deno run --allow-net --allow-env --allow-read synthesis-worker/index.ts --dry-run",
    "schema": "surreal import --endpoint http://127.0.0.1:8000 --username root --password root --namespace anima --database memory schema/anima.surql"
  }
}
