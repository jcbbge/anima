#!/usr/bin/env bash
set -euo pipefail

# Anima CLI - Simple memory interface
ANIMA_URL="${ANIMA_URL:-http://localhost:7100}"
API_BASE="$ANIMA_URL/api/v1"

ensure_services() {
    if curl -sf "$ANIMA_URL/health" > /dev/null 2>&1; then
        return 0
    fi
    
    echo "Starting Anima services..."
    cd "$HOME/anima" && docker compose up -d
    
    for i in {1..30}; do
        if curl -sf "$ANIMA_URL/health" > /dev/null 2>&1; then
            echo "Ready."
            return 0
        fi
        sleep 1
    done
    
    echo "Failed to start services"
    exit 1
}

cmd_bootstrap() {
    ensure_services
    local limit="${1:-10}"
    
    local response=$(curl -s "$API_BASE/memories/bootstrap?limit=$limit")
    
    echo "👻 GHOST HANDSHAKE"
    echo "─────────────────────────────────────────────────────────────"
    echo "$response" | jq -r '.data.ghostHandshake'
    echo "─────────────────────────────────────────────────────────────"
    echo ""
    
    local total=$(echo "$response" | jq '.data.distribution.total')
    echo "Loaded $total memories"
}

cmd_store() {
    ensure_services
    local content="$1"
    
    local response=$(curl -s -X POST "$API_BASE/memories/add" \
        -H "Content-Type: application/json" \
        -d "{\"content\": \"$content\"}")
    
    local id=$(echo "$response" | jq -r '.data.memory.id')
    local isDuplicate=$(echo "$response" | jq -r '.data.isDuplicate')
    
    if [ "$isDuplicate" = "true" ]; then
        echo "Memory exists"
    else
        echo "Stored: $id"
    fi
}

cmd_query() {
    ensure_services
    local query="$1"
    local limit="${2:-10}"
    
    local response=$(curl -s -X POST "$API_BASE/memories/query" \
        -H "Content-Type: application/json" \
        -d "{\"query\": \"$query\", \"limit\": $limit}")
    
    echo "$response" | jq -r '.data.memories[] | "\n[\(.similarity | tostring | .[:4])] \(.content[:100])..."'
}

cmd_stats() {
    ensure_services
    
    local response=$(curl -s "$API_BASE/memories/bootstrap?limit=1")
    local total=$(echo "$response" | jq '.data.distribution.total // 0')
    
    echo "Memories: $total"
}

cmd_help() {
    echo "Anima - Memory that persists across conversations"
    echo ""
    echo "Usage:"
    echo "  anima bootstrap [limit]     Load context for new session"
    echo "  anima store \"text\"          Save a memory"
    echo "  anima query \"text\" [limit]  Search memories"
    echo "  anima stats                 Show system status"
    echo "  anima help                  Show this help"
}

case "${1:-help}" in
    bootstrap)
        shift
        cmd_bootstrap "$@"
        ;;
    store)
        shift
        if [ -z "${1:-}" ]; then
            echo "Usage: anima store \"content\""
            exit 1
        fi
        cmd_store "$@"
        ;;
    query)
        shift
        if [ -z "${1:-}" ]; then
            echo "Usage: anima query \"search term\" [limit]"
            exit 1
        fi
        cmd_query "$@"
        ;;
    stats)
        cmd_stats
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        echo "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
