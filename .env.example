# Anima Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# SurrealDB Connection
SURREAL_URL=ws://127.0.0.1:8002/rpc
SURREAL_NS=anima
SURREAL_DB=memory
SURREAL_USER=root
SURREAL_PASS=root

# Ollama Configuration
OLLAMA_URL=http://localhost:8001
OLLAMA_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Synthesis Profile (options: default, fast, capable)
SYNTHESIS_PROFILE=default

# Grader Profile (options: default, fast, capable)
GRADER_PROFILE=capable

# OpenRouter API Key (REQUIRED for synthesis worker)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here
